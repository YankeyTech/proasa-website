# ---- App ----
PORT=3000
NODE_ENV=production
SESSION_SECRET=change-this-to-a-long-random-string

# ---- Aiven MySQL ----
# Find these in your Aiven console -> your MySQL service -> Overview -> Connection information
DB_HOST=your-service-name.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your-aiven-password
DB_NAME=defaultdb
# Aiven requires SSL. Leave this as true.
DB_SSL=true

# ---- Cloudinary (image & video storage) ----
# Find these on your Cloudinary Dashboard homepage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- First admin account (used only by scripts/create-admin.js) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
