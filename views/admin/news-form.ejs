<%- include('../partials/header') %>
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
<section class="section admin-section">
  <div class="wrap wrap-narrow">
    <h1><%= article ? 'Edit Article' : 'New Article' %></h1>
    <form method="POST" action="<%= article ? `/admin/news/${article.id}/edit` : '/admin/news/new' %>" enctype="multipart/form-data" class="stack-form">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" required value="<%= article ? article.title : '' %>">
      <label for="summary">Short summary (shown in listings)</label>
      <input type="text" id="summary" name="summary" maxlength="500" value="<%= article ? (article.summary || '') : '' %>">
      <label for="content">Full content</label>
      <div id="editor-content" style="background:#fff; border-radius: var(--radius);"></div>
      <textarea id="content" name="content" style="display:none;"><%= article ? article.content : '' %></textarea>
      <p class="field-hint">Use the toolbar to format text, add links, and insert images.</p>
      <label for="image">Cover image <% if (article && article.image_url) { %>(uploading a new one replaces the current image)<% } %></label>
      <input type="file" id="image" name="image" accept="image/*">
      <% if (article && article.image_url) { %>
        <img src="<%= article.image_url %>" alt="Current cover" class="current-media-preview">
      <% } %>
      <label class="checkbox-label">
        <input type="checkbox" name="is_published" <%= (!article || article.is_published) ? 'checked' : '' %>>
        Published (visible to the public)
      </label>
      <button type="submit" class="btn btn-primary"><%= article ? 'Save changes' : 'Publish article' %></button>
      <a href="/admin/news" class="btn btn-ghost">Cancel</a>
    </form>
  </div>
</section>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<script>
  var quill = new Quill('#editor-content', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [2, 3, false] }],
        ['bold', 'italic', 'underline'],
        ['link', 'image'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['clean']
      ]
    }
  });
quill.root.addEventListener('paste', function(e) {
    var clipboardData = e.clipboardData || window.clipboardData;
    if (!clipboardData) return;
    if (clipboardData.getData('text/html')) return; // rich paste (e.g. from Word) — let Quill handle it normally
    var text = clipboardData.getData('text/plain');
    if (!text) return;
    e.preventDefault();
    var paragraphs = text.split(/\n\s*\n/).map(function(p) {
      var safe = p.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\n/g, '<br>');
      return '<p>' + safe + '</p>';
    }).join('');
    var range = quill.getSelection(true);
    quill.clipboard.dangerouslyPasteHTML(range.index, paragraphs, 'user');
  });

 var contentField = document.getElementById('content');
  var initialDelta = quill.clipboard.convert({ html: contentField.value });
  quill.setContents(initialDelta, 'silent');
  quill.on('text-change', function() {
    contentField.value = quill.root.innerHTML;
  });
  document.querySelector('.stack-form').addEventListener('submit', function(e) {
    contentField.value = quill.root.innerHTML;
    if (quill.getText().trim().length === 0) {
      e.preventDefault();
      alert('Please write some content before publishing.');
    }
  });
</script>
<%- include('../partials/footer') %>