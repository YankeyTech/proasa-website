<%- include('../partials/header') %>

<section class="section admin-section">
  <div class="wrap">
    <h1>Manage Gallery</h1>

    <div class="admin-card">
      <h3>Upload new photo or video</h3>
      <form method="POST" action="/admin/gallery/new" enctype="multipart/form-data" class="stack-form">
        <label for="media">Photo or video file</label>
        <input type="file" id="media" name="media" accept="image/*,video/*" required>

        <label for="title">Title (optional)</label>
        <input type="text" id="title" name="title">

        <label for="caption">Caption (optional)</label>
        <input type="text" id="caption" name="caption">

        <button type="submit" class="btn btn-primary">Upload</button>
      </form>
    </div>

    <% if (items.length === 0) { %>
      <p class="empty-note">No gallery items yet.</p>
    <% } else { %>
      <div class="admin-gallery-grid">
        <% items.forEach(function(item) { %>
          <div class="admin-gallery-item">
            <% if (item.media_type === 'video') { %>
              <video src="<%= item.media_url %>" muted playsinline></video>
            <% } else { %>
              <img src="<%= item.media_url %>" alt="<%= item.caption || '' %>">
            <% } %>
            <form method="POST" action="/admin/gallery/<%= item.id %>/delete" onsubmit="return confirm('Delete this item?');">
              <button type="submit" class="btn btn-ghost btn-small">Delete</button>
            </form>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
