<%- include('partials/header') %>

<section class="page-hero">
  <div class="wrap">
    <p class="eyebrow">The Gazette</p>
    <h1>News &amp; Updates</h1>
  </div>
</section>

<section class="section">
  <div class="wrap wrap-narrow">
    <% if (items.length === 0) { %>
      <p class="empty-note">No news posted yet. Check back soon.</p>
    <% } else { %>
      <div class="news-cards">
        <% items.forEach(function(item) { %>
          <a class="news-card" href="/news/<%= item.slug %>">
            <% if (item.image_url) { %>
              <div class="news-card-img"><img src="<%= item.image_url %>" alt="<%= item.title %>" loading="lazy"></div>
            <% } %>
            <div class="news-card-body">
              <span class="news-date"><%= new Date(item.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
              <h3><%= item.title %></h3>
              <% if (item.summary) { %><p><%= item.summary %></p><% } %>
              <span class="link-more">Read more &rarr;</span>
            </div>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
